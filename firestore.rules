rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128; 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }

    // Schema Validation Helpers
    function isValidLead(data) {
      return data.id is string
        && data.parentName is string && data.parentName.size() <= 200
        && data.parentPhone is string && data.parentPhone.size() <= 64
        && data.childName is string && data.childName.size() <= 100
        && data.childSurname is string && data.childSurname.size() <= 100;
    }

    function isValidClient(data) {
      return data.id is string
        && data.parentName is string && data.parentName.size() <= 200
        && data.parentPhone is string && data.parentPhone.size() <= 64
        && data.childName is string && data.childName.size() <= 100
        && data.childSurname is string && data.childSurname.size() <= 100
        && data.status is string;
    }

    function isValidTask(data) {
      return data.id is string
        && data.title is string && data.title.size() <= 300
        && data.status is string
        && data.assignedTo is string;
    }

    function isValidGroup(data) {
      return data.id is string
        && data.name is string && data.name.size() <= 100
        && data.coachId is string;
    }

    function isValidCoach(data) {
      return data.id is string
        && data.name is string && data.name.size() <= 200;
    }

    function isValidFinance(data) {
      return data.id is string
        && data.type is string
        && data.category is string
        && data.amount is number;
    }

    function isValidMessage(data) {
      return data.id is string
        && data.senderRole is string
        && data.senderName is string
        && data.text is string;
    }

    function isValidTrainingSession(data) {
      return data.id is string
        && data.groupId is string
        && data.groupName is string
        && data.date is string
        && data.dateString is string
        && data.coachId is string
        && data.coachName is string
        && data.presentCount is number
        && data.sickCount is number
        && data.absentCount is number
        && data.records is list;
    }

    function isValidAccount(data) {
      return data.id is string
        && data.name is string
        && data.type is string
        && data.balance is number;
    }

    // Collections
    match /leads/{leadId} {
      allow read: if true;
      allow create, update: if isValidId(leadId) && isValidLead(incoming());
      allow delete: if true;
    }

    match /clients/{clientId} {
      allow read: if true;
      allow create, update: if isValidId(clientId) && isValidClient(incoming());
      allow delete: if true;
    }

    match /tasks/{taskId} {
      allow read: if true;
      allow create, update: if isValidId(taskId) && isValidTask(incoming());
      allow delete: if true;
    }

    match /groups/{groupId} {
      allow read: if true;
      allow create, update: if isValidId(groupId) && isValidGroup(incoming());
      allow delete: if true;
    }

    match /coaches/{coachId} {
      allow read: if true;
      allow create, update: if isValidId(coachId) && isValidCoach(incoming());
      allow delete: if true;
    }

    match /finances/{recordId} {
      allow read: if true;
      allow create, update: if isValidId(recordId) && isValidFinance(incoming());
      allow delete: if true;
    }

    match /messages/{messageId} {
      allow read: if true;
      allow create, update: if isValidId(messageId) && isValidMessage(incoming());
      allow delete: if true;
    }

    match /training_sessions/{sessionId} {
      allow read: if true;
      allow create, update: if isValidId(sessionId) && isValidTrainingSession(incoming());
      allow delete: if true;
    }

    match /accounts/{accountId} {
      allow read: if true;
      allow create, update: if isValidId(accountId) && isValidAccount(incoming());
      allow delete: if true;
    }

    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    match /systemUsers/{userId} {
      allow read, write: if true;
    }

    match /_config/{configId} {
      allow read, write: if true;
    }

    match /test/{testId} {
      allow read, write: if true;
    }
  }
}
